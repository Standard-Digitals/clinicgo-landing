{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist-api",
    "rootDir": "./api",
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["api/**/*.ts"]
}
