{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.ts": {
      "includeFiles": "api/lib.ts"
    }
  },
  "rewrites": [
    { "source": "/licence-api/activate.php", "destination": "/api/license-activate" },
    { "source": "/licence-api/verify.php", "destination": "/api/license-verify" },
    { "source": "/licence-api/deactivate.php", "destination": "/api/license-deactivate" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
